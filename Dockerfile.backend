# Stage 1: Builder
FROM python:3.11-slim-bookworm AS builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Install requirements
COPY requirements.txt .
RUN pip install --user --no-cache-dir -r requirements.txt

# Stage 2: Final
FROM python:3.11-slim-bookworm

WORKDIR /app

# Install runtime dependencies ONLY
RUN apt-get update && apt-get install -y \
    libgl1-mesa-glx \
    libglib2.0-0 \
    tesseract-ocr \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder
COPY --from=builder /root/.local /root/.local
ENV PATH=/root/.local/bin:$PATH

# Create logs directory
RUN mkdir -p /app/logs && chmod 777 /app/logs

# Copy application code
COPY passport_analysis_agent/ /app/passport_analysis_agent/
COPY financial_document_agent/ /app/financial_document_agent/
COPY education_credential_agent/ /app/education_credential_agent/
COPY master_orchestrator_agent/ /app/master_orchestrator_agent/
COPY document_analysis_ui/backend/ /app/document_analysis_ui/backend/
COPY ["conditional letter_v1.docx", "."]

# Install agents in editable mode
# Note: Since they are local, we keep them in editable mode or just install them
RUN pip install --no-cache-dir -e /app/passport_analysis_agent && \
    pip install --no-cache-dir -e /app/financial_document_agent && \
    pip install --no-cache-dir -e /app/education_credential_agent && \
    pip install --no-cache-dir -e /app/master_orchestrator_agent && \
    pip install --no-cache-dir -e /app/document_analysis_ui/backend

ENV PYTHONPATH="/app/document_analysis_ui/backend:/app/master_orchestrator_agent/src:/app/passport_analysis_agent/src:/app/education_credential_agent/src:/app/financial_document_agent/src"
ENV PYTHONUNBUFFERED=1

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
